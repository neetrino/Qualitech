# Application
NODE_ENV="development"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Database (Neon PostgreSQL) — copy connection string from Neon dashboard
DATABASE_URL=""
DATABASE_CONNECTION_LIMIT="10"
DATABASE_POOL_TIMEOUT="20"

# Admin auth (Phase 5) — generate a strong random secret (min 32 chars); never commit real values
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# Optional: create first admin on seed (`pnpm db:seed`) when DB has zero AdminUser rows
ADMIN_SEED_EMAIL=""
ADMIN_SEED_PASSWORD=""
# Set to "true" once to (re)apply ADMIN_SEED_PASSWORD for ADMIN_SEED_EMAIL (dev / password reset)
ADMIN_SEED_SYNC_PASSWORD=""


# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""


# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="test@neetrino.com"
# Inbox for contact form notifications (optional; if unset, email notify is skipped)
CONTACT_INBOX_EMAIL=""

# ——— Contact form (optional reCAPTCHA) ———
# When set, POST /api/contact requires body.recaptchaToken (v2 or v3)
RECAPTCHA_SECRET_KEY=""
# Site key for the contact form (v3 recommended); must pair with RECAPTCHA_SECRET_KEY
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# ——— File storage (Cloudflare R2) ———
# Admin: POST /api/admin/upload (multipart, auth) → R2; keys under machines/ and blog/ (presign still at /api/admin/upload/presign)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public origin for objects (no trailing slash), e.g. https://pub-xxxxx.r2.dev or custom domain
R2_PUBLIC_URL=""

# ——— Figma (MCP) ———
FIGMA_ACCESS_TOKEN=""

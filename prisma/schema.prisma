generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppLocale {
  ru
  en
}

/// Hierarchy: parentId null = top-level category (plan: 3 main sections + subcategories).
model MachineCategory {
  id        String            @id @default(cuid())
  parentId  String?
  parent    MachineCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  MachineCategory[] @relation("CategoryTree")
  sortOrder Int               @default(0)
  /// Eligible for home #solutions strip (first N by sort order among top-level categories).
  featured  Boolean           @default(false)
  /// Shown on public `/machines` catalog when true.
  published Boolean           @default(true)
  /// Public catalog card image (R2 URL); optional — falls back to first machine cover in subtree.
  imageUrl  String?           @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  translations MachineCategoryTranslation[]
  machines     Machine[]
}

model MachineCategoryTranslation {
  id         String          @id @default(cuid())
  categoryId String
  category   MachineCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale     AppLocale
  name       String
  slug       String
  /// Home card body (plain text).
  homeDescription String?  @db.Text
  /// Home card bullet lines (uppercase styling on the public page).
  homeBullets     String[] @default([])
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([locale, slug])
  @@index([categoryId])
}

model Machine {
  id         String           @id @default(cuid())
  /// Single URL segment for all locales: `/[locale]/machines/[category]/[slug]`.
  slug       String           @unique
  categoryId String?
  category   MachineCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  featured   Boolean          @default(false)
  published  Boolean          @default(false)
  sortOrder  Int              @default(0)
  /// Optional product sheet / brochure (public URL, e.g. R2).
  pdfUrl     String?          @db.Text
  /// Optional Excel specs sheet (public URL, e.g. R2 `.xlsx` / `.xls`).
  excelUrl   String?          @db.Text
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  translations MachineTranslation[]
  images       MachineImage[]

  @@index([categoryId])
  @@index([published, featured])
}

/// Per-locale SEO + copy (plan: meta, OG image, gallery URLs on machine).
model MachineTranslation {
  id               String    @id @default(cuid())
  machineId        String
  machine          Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)
  locale           AppLocale
  title            String
  /// Rich HTML (admin WYSIWYG); sanitized on save.
  description      String    @db.Text
  metaTitle        String?
  metaDescription  String?   @db.Text
  ogImageUrl       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([machineId, locale])
  @@index([machineId])
}

model MachineImage {
  id        String   @id @default(cuid())
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
  /// Hero / catalog card / OG when synced from admin.
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([machineId, sortOrder])
}

model BlogPost {
  id          String    @id @default(cuid())
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  translations BlogPostTranslation[]
  images       BlogPostImage[]

  @@index([published, publishedAt])
}

model BlogPostTranslation {
  id              String    @id @default(cuid())
  postId          String
  post            BlogPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  locale          AppLocale
  title           String
  slug            String
  excerpt         String    @db.Text
  content         String    @db.Text
  metaTitle       String?
  metaDescription String?   @db.Text
  ogImageUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([locale, slug])
  @@index([postId])
}

model BlogPostImage {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([postId, sortOrder])
}

model ContactMessage {
  id               String    @id @default(cuid())
  name             String
  email            String
  message          String    @db.Text
  idempotencyKey   String?   @unique
  createdAt        DateTime  @default(now())
  readAt           DateTime?

  @@index([createdAt])
}

/// Admin credentials; password set via argon2 hash in app layer (Phase 5).
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
